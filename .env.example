# ─── Wallet ────────────────────────────────────────────────────────────────
# EOA private key (hex, with or without 0x prefix). NEVER commit this.
PRIVATE_KEY=

# ─── Chain ─────────────────────────────────────────────────────────────────
RPC_URL=https://mainnet.base.org

# ─── Bounty ─────────────────────────────────────────────────────────────────
BOUNTY_NAME=Show this code in public
BOUNTY_DESCRIPTION=Take a real-world photo of a handwritten note that says "POIDH BOT 31" in a public place. The photo must clearly show the handwritten text and a real physical environment. Screens, edited overlays, AI-generated images, or fully digital images are invalid.
BOUNTY_AMOUNT_ETH=0.001
# Hours from creation until deadline. Bot will wait and accept after this.
BOUNTY_DEADLINE_HOURS=168

# ─── Polling ────────────────────────────────────────────────────────────────
# Seconds between each poll for new claims. 300 = 5 minutes.
POLL_INTERVAL_SECONDS=300

# ─── Scoring ────────────────────────────────────────────────────────────────
# Minimum score (out of 10) to be considered valid.
MIN_SCORE=7.5
# Phrase to look for in OCR output.
TARGET_PHRASE=POIDH BOT 31

# ─── Paths ─────────────────────────────────────────────────────────────────
LOG_DIR=./logs
DATA_DIR=./data

# ─── Social / Public Posting ────────────────────────────────────────────────
# PRODUCTION MODE (required for bounty submission):
# Set to true to enforce real public posting. Bot will STOP if credentials are missing.
REQUIRE_PUBLIC_POST=false

# Platform: "mock" (local file), "farcaster" (Neynar/Farcaster), "x" (Twitter/X)
# When REQUIRE_PUBLIC_POST=true, must be "farcaster" or "x" (not "mock").
SOCIAL_PLATFORM=farcaster

# Faracster (Neynar v2) — required when SOCIAL_PLATFORM=farcaster
# Get keys at: https://neynar.com/
NEYNAR_API_KEY=
FARCASTER_SIGNER_UUID=

# Twitter/X — required when SOCIAL_PLATFORM=x
# Requires Twitter Developer Elevated access (free sandbox cannot post).
# Get keys at: https://developer.twitter.com/
X_BEARER_TOKEN=
X_API_KEY=
X_API_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_TOKEN_SECRET=
